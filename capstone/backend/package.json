{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test:db:up": "docker compose -f tests/docker-compose.test.yml up -d",
    "test:db:wait": "wait-on tcp:5433",
    "test:db:down": "docker compose -f tests/docker-compose.test.yml down -v",
    "test:db:init": "cross-env NODE_ENV=test ts-node tests/init-test-db.ts",
    "test:run": "cross-env NODE_ENV=test jest --runInBand",
    "test": "npm run test:db:up && npm run test:db:wait && npm run test:db:init && npm run test:run && npm run test:db:down"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "firebase-admin": "^13.6.1",
    "handlebars": "^4.7.9",
    "jest": "^30.4.2",
    "multer": "^2.1.1",
    "pg": "^8.18.0",
    "puppeteer": "^24.43.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "cross-env": "^10.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.10"
  }
}
